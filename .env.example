# Leave DATABASE_URL empty only for local demo mode. Production intake fails closed without durable storage.
DATABASE_URL=
# Local development may use loopback HTTP. Preview and production require the canonical public HTTPS origin.
APP_BASE_URL=http://localhost:3000
PROPERTY_OS_ORG_ID=sample-org
PROPERTY_OS_DEMO_AUTH=false
PROPERTY_OS_DEMO_RUNTIME=false

# Choose one owner identity mode. The private pilot is for one trusted owner only.
PROPERTY_OS_AUTH_MODE=static-private-pilot

# Private single-owner pilot. Generate the hash with:
# npm run auth:hash -- "private owner passcode"
OWNER_PORTAL_SECRET=""
OWNER_PORTAL_PASSCODE_HASH=""

# Agency/multi-owner mode. Set PROPERTY_OS_AUTH_MODE=oidc and configure every key below.
# Callback: ${APP_BASE_URL}/api/auth/oauth2/callback/property-os-oidc
BETTER_AUTH_SECRET=""
PROPERTY_OS_OIDC_ISSUER=""
PROPERTY_OS_OIDC_AUTHORIZATION_URL=""
PROPERTY_OS_OIDC_TOKEN_URL=""
PROPERTY_OS_OIDC_JWKS_URL=""
PROPERTY_OS_OIDC_CLIENT_ID=""
PROPERTY_OS_OIDC_CLIENT_SECRET=""
PROPERTY_OS_OIDC_PROVIDER_ID=property-os-oidc
PROPERTY_OS_OIDC_ORGANIZATION_CLAIM=organization_id
PROPERTY_OS_OIDC_ROLE_CLAIM=role
# Activation-only comma-separated subjects verified by npm run identity:db:smoke.
PROPERTY_OS_EXPECTED_OIDC_SUBJECTS=""

# Optional sanitized issue destination.
GITHUB_ISSUE_REPO=

# Future adapters. Keep unset until configured and reviewed.
RUNTIME_STORE=
EMAIL_PROVIDER=
OBJECT_STORAGE_PROVIDER=

# Agent runtime. Required before enabling hosted specialist missions.
MCP_SERVER_URL=
MCP_SERVER_AUTH_MODE=static
MCP_SERVER_ACCESS_TOKEN=
MCP_SERVER_ORIGIN=
MCP_REQUEST_TIMEOUT_MS=8000

# Agency MCP connection. Select oidc-client-credentials and leave MCP_SERVER_ACCESS_TOKEN empty.
MCP_OIDC_TOKEN_URL=
MCP_OIDC_CLIENT_ID=
MCP_OIDC_CLIENT_SECRET=
MCP_OIDC_AUDIENCE=
MCP_OIDC_SCOPE="property:read property:draft property:approve property:apply:internal"

# Signed owner-notification routes. Production urgent handling requires both routes and a scoped worker token.
OWNER_NOTIFICATION_WEBHOOK_URL=
OWNER_NOTIFICATION_WEBHOOK_SIGNING_SECRET=
OWNER_NOTIFICATION_FALLBACK_WEBHOOK_URL=
OWNER_NOTIFICATION_FALLBACK_SIGNING_SECRET=
OWNER_NOTIFICATION_WORKER_TOKEN=
OWNER_NOTIFICATION_MAX_ATTEMPTS=3
OWNER_NOTIFICATION_RETRY_BASE_MS=60000
OWNER_NOTIFICATION_ACK_TIMEOUT_MS=300000
OWNER_NOTIFICATION_CLAIM_LEASE_MS=30000
OWNER_NOTIFICATION_REQUEST_TIMEOUT_MS=6000
OWNER_NOTIFICATION_BATCH_SIZE=10

# Model provider keys belong only in the hosted MCP/Railway secret store, never in this portal.
