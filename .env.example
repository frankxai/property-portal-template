# Leave DATABASE_URL empty for demo mode.
DATABASE_URL=
APP_BASE_URL=http://localhost:3000
PROPERTY_OS_ORG_ID=sample-org
PROPERTY_OS_DEMO_AUTH=false

# Built-in owner/admin gate. Generate with:
# npm run auth:hash -- "private owner passcode"
OWNER_PORTAL_SECRET=""
OWNER_PORTAL_PASSCODE_HASH=""
OWNER_PORTAL_API_TOKEN=""

# Optional sanitized issue destination.
GITHUB_ISSUE_REPO=

# Future adapters. Keep unset until configured and reviewed.
RUNTIME_STORE=
EMAIL_PROVIDER=
OBJECT_STORAGE_PROVIDER=

# Production identity provider and agent runtime. Required before using real renter data at SaaS/agency scale.
AUTH_PROVIDER=
OWNER_ADMIN_EMAIL=
MCP_SERVER_URL=
MCP_SERVER_ACCESS_TOKEN=
MCP_SERVER_ORIGIN=
MCP_REQUEST_TIMEOUT_MS=8000

# Signed owner-notification routes. Production urgent handling requires both routes and a scoped worker token.
OWNER_NOTIFICATION_WEBHOOK_URL=
OWNER_NOTIFICATION_WEBHOOK_SIGNING_SECRET=
OWNER_NOTIFICATION_FALLBACK_WEBHOOK_URL=
OWNER_NOTIFICATION_FALLBACK_SIGNING_SECRET=
OWNER_NOTIFICATION_WORKER_TOKEN=
OWNER_NOTIFICATION_MAX_ATTEMPTS=3
OWNER_NOTIFICATION_RETRY_BASE_MS=60000
OWNER_NOTIFICATION_ACK_TIMEOUT_MS=300000
OWNER_NOTIFICATION_CLAIM_LEASE_MS=30000
OWNER_NOTIFICATION_REQUEST_TIMEOUT_MS=6000
OWNER_NOTIFICATION_BATCH_SIZE=10

# Model provider keys belong only in the hosted MCP/Railway secret store, never in this portal.
